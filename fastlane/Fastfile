# Fastfile — DICOM Viewer
# iOS (TestFlight / App Store), macOS (TestFlight / Mac App Store), Android (Google Play)
# Run from the project root:
#   bundle exec fastlane ios beta      # iOS → TestFlight
#   bundle exec fastlane mac beta      # macOS → TestFlight
#   bundle exec fastlane ios release   # iOS → App Store review
#   bundle exec fastlane mac release   # macOS → Mac App Store review
#   bundle exec fastlane android beta  # Android → Play internal

# Workaround: OpenSSL 3.x (Ruby 3.4+) dropped OpenSSL::PKey::EC.new(pem_string).
# Fastlane's spaceship loads the .p8 API key that way; patch it to use
# OpenSSL::PKey.read, which is compatible across OpenSSL versions.
require 'openssl'
require 'base64'
module OpenSSLECKeyPatch
  def new(*args, &block)
    if args.length == 1 && args.first.is_a?(String) && args.first.include?("-----")
      OpenSSL::PKey.read(args.first)
    else
      super
    end
  end
end
OpenSSL::PKey::EC.singleton_class.prepend(OpenSSLECKeyPatch)

def resolve_asc_private_key(raw_value)
  return nil if raw_value.to_s.strip.empty?

  raw = raw_value.strip

  # Support base64-encoded PEM (recommended for CI secrets).
  begin
    decoded = Base64.strict_decode64(raw)
    return decoded if decoded.include?("BEGIN PRIVATE KEY")
  rescue ArgumentError
    # Not base64 — fall through to raw PEM handling.
  end

  # Support ".env-style" single-line PEM with literal "\n".
  pem = raw.gsub("\\n", "\n")
  return pem if pem.include?("BEGIN PRIVATE KEY")

  nil
end

# ── Shared helpers ─────────────────────────────────────────────────────────────

# Read version and build number from pubspec.yaml (fastlane/ is one level below it).
def pubspec
  @pubspec ||= File.read(File.join(__dir__, "..", "pubspec.yaml"))
end

def pubspec_version
  pubspec.match(/^version:\s+(\d+\.\d+\.\d+)\+(\d+)/)
end

def app_version
  pubspec_version[1]
end

def build_number
  pubspec_version[2].to_i
end

# Apple Developer Team ID. Falls back to the known team when the env var is
# unset OR empty. GitHub injects "" for an absent secret, and Ruby treats ""
# as truthy, so a plain `ENV[...] || default` would leak an empty
# DEVELOPMENT_TEAM and break signing with "No Team Found in Archive" (export)
# / "requires a development team" (archive).
def apple_team_id
  value = ENV["APPLE_TEAM_ID"].to_s.strip
  value.empty? ? "844T7SAJPK" : value
end

# Keychain options for match on CI so the imported signing identity lands in the
# dedicated, unlocked keychain (created by setup_ci_keychain with a real
# password) rather than login.keychain. Passing the password explicitly lets
# match's `security set-key-partition-list` succeed; otherwise codesign blocks
# on a keychain-authorization prompt during the build_app/build_mac_app
# "Run Script" phase and the job hangs until the job timeout.
def match_keychain_params
  return {} unless ENV["MATCH_KEYCHAIN_NAME"] && ENV["MATCH_KEYCHAIN_PASSWORD"]
  {
    keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
    keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
  }
end

# Bump the build number in pubspec.yaml and return the new value.
def bump_pubspec_build(new_build)
  path = File.join(__dir__, "..", "pubspec.yaml")
  content = File.read(path)
  updated = content.gsub(
    /^(version:\s+\d+\.\d+\.\d+\+)\d+/,
    "\\1#{new_build}"
  )
  File.write(path, updated)
  new_build
end

# Set up a dedicated, unlocked keychain on CI with a NON-empty password.
# setup_circle_ci creates the keychain with an empty password, which makes
# `security set-key-partition-list -k ""` silently fail on GitHub-hosted
# runners — codesign then hangs waiting for keychain authorization during the
# Flutter "Run Script" phase of build_app/build_mac_app. Using a real password
# lets match's partition-list call succeed and grants codesign access.
def setup_ci_keychain
  return unless RUBY_PLATFORM.include?("darwin")
  require "securerandom"
  require "shellwords"

  name = ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_ci.keychain")
  pwd = SecureRandom.hex(12)
  ENV["MATCH_KEYCHAIN_NAME"] = name
  ENV["MATCH_KEYCHAIN_PASSWORD"] = pwd

  sh("security delete-keychain #{name.shellescape} 2>/dev/null || true")
  create_keychain(
    name: name,
    password: pwd,
    default_keychain: true,
    unlock: true,
    timeout: 0,
    lock_when_sleeps: false,
    add_to_search_list: true
  )
end

before_all do |lane, options|
  setup_ci_keychain if is_ci

  # Write the App Store Connect API key from the APPLE_AUTHKEY env var so the
  # asc_api_key helper can load it by file path (key_filepath avoids the
  # OpenSSL 3.x key_content path).
  if ENV["APPLE_AUTHKEY"] && !ENV["APPLE_AUTHKEY"].empty?
    key_path = File.expand_path("~/.appstoreconnect/private_keys/AuthKey.p8")
    FileUtils.mkdir_p(File.dirname(key_path))
    key_content = resolve_asc_private_key(ENV["APPLE_AUTHKEY"])

    UI.user_error!("APPLE_AUTHKEY must be base64 PEM or raw PEM with literal \\n") unless key_content

    File.write(key_path, key_content)
    UI.message("ASC API key written (#{key_content.length} bytes) -> #{key_path}")
  else
    UI.important("APPLE_AUTHKEY env var not set — API key will not be available")
  end
end

# Shared App Store Connect API key (avoids 2FA prompts).
# Expects: ASC_ISSUER_ID, ASC_KEY_ID, APPLE_AUTHKEY.
def asc_api_key
  issuer = ENV["ASC_ISSUER_ID"]
  key_id = ENV["ASC_KEY_ID"] || "532BJ2V2G4"
  if issuer.to_s.empty?
    UI.user_error!("ASC_ISSUER_ID is not set. Add it to fastlane/.env (or CI secrets).")
  end
  if ENV["APPLE_AUTHKEY"].to_s.empty?
    UI.user_error!("APPLE_AUTHKEY is not set. Add it to fastlane/.env (or CI secrets).")
  end

  UI.message("ASC API key_id=#{key_id} issuer_id=#{issuer&.slice(0, 8)}...#{issuer&.slice(-4, 4)}")
  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer,
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey.p8"),
    duration: 1200,
    in_house: false
  )
end

error do |lane, exception|
  UI.error("Lane '#{lane}' failed: #{exception.message}")
end

# ── iOS ───────────────────────────────────────────────────────────────────────

platform :ios do
  desc "Sync certificates and provisioning profiles via Match"
  lane :sync_certificates do |options|
    match_params = {
      type: options[:type] || "appstore",
      readonly: is_ci,
      app_identifier: ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      api_key: asc_api_key
    }
    match_params[:git_basic_authorization] = ENV["MATCH_GIT_BASIC_AUTHORIZATION"] if ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    match_params.merge!(match_keychain_params)
    match(match_params)
  end

  desc "Build the Flutter iOS app (release, signed)"
  lane :build do
    sh("flutter pub get", chdir: "..")
    cocoapods(podfile: "ios/Podfile", use_bundle_exec: true)
    sync_certificates

    # Flutter build first (no-codesign — Xcode signs during the archive step).
    sh("flutter build ios --release --no-codesign", chdir: "..")

    app_id = ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer"
    team = apple_team_id
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios/output",
      output_name: "DicomViewer.ipa",
      include_symbols: true,
      include_bitcode: false,
      codesigning_identity: "Apple Distribution",
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{team} 'PROVISIONING_PROFILE_SPECIFIER=match AppStore #{app_id}'"
    )
  end

  desc "Bump build number from latest TestFlight build"
  lane :bump_build do
    latest = begin
      latest_testflight_build_number(
        app_identifier: ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
        api_key: asc_api_key
      )
    rescue => e
      UI.important("Could not fetch TestFlight build number (#{e.message}), defaulting to 0")
      0
    end
    new_build = bump_pubspec_build(latest + 1)
    UI.success("Build number bumped to #{new_build}")
  end

  desc "Build and upload to TestFlight (internal beta)"
  lane :beta do
    bump_build
    build
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
    UI.success("iOS #{app_version} (#{build_number}) uploaded to TestFlight")
  end

  desc "Build and submit to App Store for review"
  lane :release do
    bump_build
    build
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      force: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
    UI.success("iOS #{app_version} submitted to App Store")
  end
end

# ── macOS ─────────────────────────────────────────────────────────────────────

platform :mac do
  desc "Sync Mac certificates and provisioning profiles via Match"
  lane :sync_certificates do |options|
    match_params = {
      type: options[:type] || "appstore",
      readonly: is_ci,
      platform: "macos",
      app_identifier: ENV["MAC_BUNDLE_ID"] || ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      api_key: asc_api_key
    }
    match_params[:git_basic_authorization] = ENV["MATCH_GIT_BASIC_AUTHORIZATION"] if ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    match_params.merge!(match_keychain_params)
    match(match_params)
  end

  desc "Build the Flutter macOS app (release, signed .pkg)"
  lane :build do
    sh("flutter pub get", chdir: "..")
    cocoapods(podfile: "macos/Podfile", use_bundle_exec: true)
    sync_certificates

    # Flutter build first (generates frameworks/plugins; intermediate signing is ad-hoc).
    sh("flutter build macos --release", chdir: "..")

    app_id = ENV["MAC_BUNDLE_ID"] || ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer"
    team = apple_team_id

    # Archive + export a Mac App Store installer package (.pkg).
    build_mac_app(
      workspace: "macos/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/macos/output",
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{team} 'PROVISIONING_PROFILE_SPECIFIER=match AppStore #{app_id}'"
    )

    pkg_path = Dir.glob(File.expand_path("build/macos/output/*.pkg")).first
    UI.user_error!("No .pkg produced in build/macos/output") unless pkg_path
    UI.success("macOS package built: #{pkg_path}")
  end

  desc "Bump build number from latest TestFlight (macOS) build"
  lane :bump_build do
    latest = begin
      latest_testflight_build_number(
        app_identifier: ENV["MAC_BUNDLE_ID"] || ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
        api_key: asc_api_key,
        platform: "osx"
      )
    rescue => e
      UI.important("Could not fetch TestFlight build number (#{e.message}), defaulting to 0")
      0
    end
    new_build = bump_pubspec_build(latest + 1)
    UI.success("Build number bumped to #{new_build}")
  end

  desc "Build and upload to TestFlight (internal beta)"
  lane :beta do
    bump_build
    build
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: ENV["MAC_BUNDLE_ID"] || ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      app_platform: "osx",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
    UI.success("macOS #{app_version} (#{build_number}) uploaded to TestFlight")
  end

  desc "Build and submit to the Mac App Store for review"
  lane :release do
    bump_build
    build
    upload_to_app_store(
      api_key: asc_api_key,
      app_identifier: ENV["MAC_BUNDLE_ID"] || ENV["IOS_BUNDLE_ID"] || "eu.imsc.dicomviewer",
      platform: "osx",
      pkg: Dir.glob(File.expand_path("build/macos/output/*.pkg")).first,
      force: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
    UI.success("macOS #{app_version} submitted to the Mac App Store")
  end
end

# ── Android ───────────────────────────────────────────────────────────────────

platform :android do
  desc "Build a signed Android App Bundle (AAB)"
  lane :build do
    sh("flutter pub get", chdir: "..")
    sh("flutter build appbundle --release", chdir: "..")
  end

  desc "Bump build number from latest Play Store internal track"
  lane :bump_build do
    latest = google_play_track_version_codes(
      package_name: ENV["ANDROID_PACKAGE_NAME"] || "eu.imsc.dicomviewer",
      track: "internal",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_PATH"] || "fastlane/google-play-key.json"
    ).max || 0

    new_build = bump_pubspec_build(latest + 1)
    UI.success("Build number bumped to #{new_build}")
  end

  desc "Build and upload AAB to Play Store internal → beta track"
  lane :beta do
    bump_build
    build
    upload_to_play_store(
      package_name: ENV["ANDROID_PACKAGE_NAME"] || "eu.imsc.dicomviewer",
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_PATH"] || "fastlane/google-play-key.json",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    UI.success("Android #{app_version} (#{build_number}) uploaded to Play Store internal track")
  end

  desc "Promote internal build to Play Store production"
  lane :release do
    upload_to_play_store(
      package_name: ENV["ANDROID_PACKAGE_NAME"] || "eu.imsc.dicomviewer",
      track: "internal",
      track_promote_to: "production",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_PATH"] || "fastlane/google-play-key.json",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    UI.success("Android #{app_version} promoted to Play Store production")
  end
end
