# ── Apple (iOS + macOS) ───────────────────────────────────────────────────────
IOS_BUNDLE_ID=eu.imsc.dicomviewer
MAC_BUNDLE_ID=eu.imsc.dicomviewer

# Apple Developer / App Store Connect credentials
APPLE_ID=you@example.com
APPLE_TEAM_ID=844T7SAJPK
ITC_TEAM_ID=844T7SAJPK            # App Store Connect team (often same as APPLE_TEAM_ID)

# App Store Connect API key (avoids 2FA — preferred for CI)
# Generate at: https://appstoreconnect.apple.com/access/api
# Key ID + issuer ID identify the key; paste the .p8 contents below.
ASC_KEY_ID=532BJ2V2G4
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPLE_AUTHKEY supports two formats:
# 1) raw PEM as a single line with literal \n between lines (example below)
# 2) base64-encoded full PEM (recommended for CI secret stores)
APPLE_AUTHKEY=-----BEGIN PRIVATE KEY-----\nMIGTA...\n-----END PRIVATE KEY-----

# Match (code signing certificate repo)
# Cert repo: https://github.com/langazov/AppleCerts.git
MATCH_PASSWORD=your-match-passphrase       # encrypts/decrypts certs in the repo

# ── Android ───────────────────────────────────────────────────────────────────
ANDROID_PACKAGE_NAME=eu.imsc.dicomviewer

# Google Play service account JSON key
# Generate at: https://play.google.com/console → Setup → API access
GOOGLE_PLAY_JSON_KEY_PATH=fastlane/google-play-key.json

# Android release keystore
KEYSTORE_PATH=android/keystore/release.jks
KEYSTORE_PASSWORD=your-keystore-password
KEY_ALIAS=your-key-alias
KEY_PASSWORD=your-key-password
